{
  "manifest_version": 3,
  "name": "WebGPU Live Subtitles",
  "version": "1.0",
  "description": "Real-time AI subtitles powered by WebGPU",
  "permissions": [
    "tabCapture",
    "offscreen",
    "scripting",
    "activeTab"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Start Subtitles"
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/content.js"],
      "run_at": "document_end"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*", 
        "wasm/*", 
        "models/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
